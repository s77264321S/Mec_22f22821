def calculate_final_total(total_amount):
    """
    Calculate the final total after applying a discount for students.

    Parameters:
    total_amount (float): The original total amount.

    Returns:
    float: The final total after discount if applicable.
    """
    if total_amount > 50:
        discount = total_amount * 0.05  # Apply a 5% discount
        total_amount -= discount
    return total_amount

# Example usage
total = 60  # Example total amount
final_total = calculate_final_total(total)
print(f"The final total after discount is: {final_total:.2f} OMR")
